# Server
PORT=3000
NODE_ENV=development
LOG_LEVEL=info

# Database (Railway provides DATABASE_URL automatically when you add Postgres)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/aaj_kya_khaun

# Twilio WhatsApp (get from Twilio Console → Messaging → Try WhatsApp)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
TWILIO_WEBHOOK_VALIDATE=true
# Public URL where Twilio should POST incoming messages (Railway gives you this).
# Only needed for webhook signature validation.
PUBLIC_BASE_URL=https://your-app.up.railway.app

# LLM — swap freely via env, no code changes needed
LLM_PROVIDER=anthropic
LLM_MODEL=claude-3-5-sonnet-20241022

# Provider API keys (set the one(s) you use)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_GENERATIVE_AI_API_KEY=
OLLAMA_BASE_URL=http://localhost:11434

# Default user timezone (used when a new user onboards)
DEFAULT_TIMEZONE=Asia/Kolkata
