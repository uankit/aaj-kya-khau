# Server
PORT=3000
NODE_ENV=development
LOG_LEVEL=info

# Database (Railway injects DATABASE_URL automatically when you add Postgres)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/aaj_kya_khaun

# Telegram — get token from @BotFather
TELEGRAM_BOT_TOKEN=
# Shared secret for webhook authentication (min 16 chars).
# Generate with: openssl rand -hex 32
TELEGRAM_WEBHOOK_SECRET=

# Public URL of the deployed server (Railway gives you this).
# Used when registering the Telegram webhook.
PUBLIC_BASE_URL=https://your-app.up.railway.app

# LLM — swap freely via env, no code changes
LLM_PROVIDER=openai
LLM_MODEL=gpt-4o

# Provider API keys (set the one you use)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_GENERATIVE_AI_API_KEY=
OLLAMA_BASE_URL=http://localhost:11434

# Default user timezone (used when a new user onboards)
DEFAULT_TIMEZONE=Asia/Kolkata

# Encryption key for OAuth tokens at rest (32 bytes base64).
# Generate with: openssl rand -base64 32
# Required once you wire up Zepto/Swiggy; optional otherwise.
ENCRYPTION_KEY=

# Zepto MCP OAuth client credentials.
# Run `npm run zepto:register-client` after PUBLIC_BASE_URL is set to mint these.
ZEPTO_CLIENT_ID=
ZEPTO_REGISTRATION_ACCESS_TOKEN=

# Twilio WhatsApp (Cloud API).
# - ACCOUNT_SID + AUTH_TOKEN: from Twilio Console
# - WHATSAPP_FROM: your approved sender, e.g. "whatsapp:+14155238886"
# - MESSAGING_SERVICE_SID: optional; only if your templates require it
# - WEBHOOK_VALIDATE: true in prod (rejects forged webhook posts);
#   set false for local tunneling tests where signature fails on rewritten URLs
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=
TWILIO_MESSAGING_SERVICE_SID=
TWILIO_WEBHOOK_VALIDATE=true

# WhatsApp template Content SIDs (one per pre-approved template in Meta).
# Get the SID from Twilio Console → Content Builder after Meta approves.
TWILIO_TEMPLATE_MEAL_NUDGE_BREAKFAST=
TWILIO_TEMPLATE_MEAL_NUDGE_LUNCH_DINNER=
TWILIO_TEMPLATE_NIGHTLY_SUMMARY=
TWILIO_TEMPLATE_RESTOCK_LOW=
TWILIO_TEMPLATE_ORDER_CONFIRMED=
